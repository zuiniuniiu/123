@model MyReservationsViewModel
@{ ViewData["Title"] = "我的预约"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-semibold mb-0">我的预约</h4>
    <a class="btn btn-primary btn-sm" asp-controller="Seat" asp-action="Index">继续预约</a>
</div>

@if (Model.Reservations.Any())
{
    <div class="table-responsive">
        <table class="table table-hover small">
            <thead class="table-light"><tr><th>座位</th><th>区域</th><th>日期</th><th>时段</th><th>状态</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td>@r.Seat?.SeatNumber</td>
                        <td>@r.Seat?.Area</td>
                        <td>@r.ReservationDate.ToString("MM-dd")</td>
                        <td>@r.TimeSlot</td>
                        <td>
                            @switch (r.Status)
                            {
                                case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Active:
                                    <span class="badge bg-primary">已预约</span>
                                    break;
                                case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Completed:
                                    <span class="badge bg-info">已完成</span>
                                    break;
                                case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Cancelled:
                                    <span class="badge bg-secondary">已取消</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (r.Status == LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Active)
                            {
                                <form asp-controller="Reservation" asp-action="Cancel" method="post" onsubmit="return confirm('确定取消该预约？')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button class="btn btn-sm btn-outline-danger">取消</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">还没有预约记录，<a asp-controller="Seat" asp-action="Index" class="alert-link">去预约 →</a></div>
}
