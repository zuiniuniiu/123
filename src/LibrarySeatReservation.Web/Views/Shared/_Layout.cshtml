<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 图书馆座位预约系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-primary sticky-top">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">座位预约</a>
            <div class="d-flex align-items-center gap-2 ms-auto">
                <a class="nav-link text-white" asp-controller="Seat" asp-action="Index">座位</a>
                <a class="nav-link text-white" asp-controller="Reservation" asp-action="MyReservations">我的预约</a>
                <span class="text-white small">当前用户：</span>
                <form asp-controller="Home" asp-action="SwitchUser" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <select name="userName" class="form-select form-select-sm d-inline" style="width:auto;background:rgba(255,255,255,0.2);color:#fff;border:none;" onchange="this.form.submit()">
                        <option value="张三" selected="@(ViewBag.CurrentUser == "张三")">张三</option>
                        <option value="李四" selected="@(ViewBag.CurrentUser == "李四")">李四</option>
                        <option value="王五" selected="@(ViewBag.CurrentUser == "王五")">王五</option>
                    </select>
                </form>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Login">管理</a>
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center mb-0">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center mb-0">@TempData["Error"]</div>
    }

    <main class="container py-3">
        @RenderBody()
    </main>

    <footer class="border-top text-muted text-center py-2" style="font-size:0.875rem;">
        &copy; @DateTime.Now.Year - 图书馆座位预约系统 · 课堂项目
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
