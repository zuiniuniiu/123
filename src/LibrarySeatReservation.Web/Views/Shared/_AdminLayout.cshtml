<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 管理后台</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold" asp-controller="Admin" asp-action="Reservation">管理后台</a>
            <div class="d-flex align-items-center gap-3">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Reservation">预约管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Seat">座位管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Statistics">统计</a>
                <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline mb-0">
                    <button class="btn btn-sm btn-outline-light">退出</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-fluid p-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
