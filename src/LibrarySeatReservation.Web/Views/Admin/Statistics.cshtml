@model StatisticsViewModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "数据统计"; }

<h5 class="fw-semibold mb-3">数据统计</h5>
<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.TotalSeats</h2><p class="text-muted small">座位总数</p></div></div>
    <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.TodayReservations</h2><p class="text-muted small">今日预约</p></div></div>
    <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.MonthReservations</h2><p class="text-muted small">本月预约</p></div></div>
</div>
@if (Model.TimeSlotDistribution.Any())
{
    <h6 class="fw-semibold mb-2">各时段预约分布</h6>
    <div class="table-responsive">
        <table class="table table-striped small"><thead class="table-light"><tr><th>时段</th><th>预约次数</th></tr></thead>
            <tbody>@foreach (var s in Model.TimeSlotDistribution) { <tr><td>@s.TimeSlot</td><td>@s.Count</td></tr> }</tbody></table>
    </div>
}
else { <div class="alert alert-info">暂无统计数据</div> }
