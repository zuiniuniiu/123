@model StatisticsViewModel
@{ Layout = null; ViewData["Title"] = "统计"; }
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>数据统计</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Admin" asp-action="Reservation">管理后台</a>
            <div class="d-flex gap-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Reservation">预约管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Seat">座位管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Statistics">统计</a>
                <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline">
                    <button class="btn btn-sm btn-outline-light">退出</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-fluid p-3">
        <h5 class="fw-semibold mb-3">数据统计</h5>
        <div class="row g-3 mb-4">
            <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.TotalSeats</h2><p class="text-muted small">座位总数</p></div></div>
            <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.TodayReservations</h2><p class="text-muted small">今日预约</p></div></div>
            <div class="col-md-4"><div class="card text-center p-3 shadow-sm"><h2 class="fw-bold text-primary">@Model.MonthReservations</h2><p class="text-muted small">本月预约</p></div></div>
        </div>
        @if (Model.TimeSlotDistribution.Any())
        {
            <h6 class="fw-semibold mb-2">各时段预约分布</h6>
            <table class="table table-striped small"><thead><tr><th>时段</th><th>次数</th></tr></thead>
                <tbody>@foreach (var s in Model.TimeSlotDistribution) { <tr><td>@s.TimeSlot</td><td>@s.Count</td></tr> }</tbody></table>
        }
        else { <div class="alert alert-info">暂无统计数据</div> }
    </div>
</body>
</html>
