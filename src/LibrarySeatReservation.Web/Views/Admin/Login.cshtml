@model AdminLoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理员登录 - 图书馆座位预约系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center" style="min-height:100vh;">
    <div class="container" style="max-width:400px;">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="text-center fw-semibold mb-4">管理员登录</h4>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger text-center small py-2">@TempData["Error"]</div>
                }
                <form asp-controller="Admin" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label class="form-label small">用户名</label>
                        <input asp-for="Username" class="form-control" placeholder="admin" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">密码</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="admin123" />
                    </div>
                    <button class="btn btn-primary w-100">登录</button>
                </form>
                <div class="text-center mt-3">
                    <a asp-controller="Home" asp-action="Index" class="small text-decoration-none">← 返回首页</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
