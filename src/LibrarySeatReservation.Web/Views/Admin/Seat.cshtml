@model List<LibrarySeatReservation.Web.Models.Entities.Seat>
@{ Layout = "_AdminLayout"; ViewData["Title"] = "座位管理"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-semibold mb-0">座位管理</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">+ 新增座位</button>
</div>
@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover small">
            <thead class="table-light"><tr><th>编号</th><th>区域</th><th>楼层</th><th>描述</th><th>状态</th><th>操作</th></tr></thead>
            <tbody>
                @foreach (var seat in Model)
                {
                    <tr>
                        <td>@seat.SeatNumber</td><td>@seat.Area</td><td>@seat.Floor</td><td>@seat.Description</td>
                        <td>
                            @switch (seat.Status)
                            {
                                case LibrarySeatReservation.Web.Models.Entities.SeatStatus.Available: <span class="badge bg-success">空闲</span> break;
                                case LibrarySeatReservation.Web.Models.Entities.SeatStatus.Booked: <span class="badge bg-primary">已预约</span> break;
                                case LibrarySeatReservation.Web.Models.Entities.SeatStatus.Maintenance: <span class="badge bg-secondary">维护中</span> break;
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal_@seat.Id">编辑</button>
                            @if (seat.Status != LibrarySeatReservation.Web.Models.Entities.SeatStatus.Booked)
                            {
                                <form asp-controller="Admin" asp-action="ToggleStatus" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@seat.Id" />
                                    <button class="btn btn-sm btn-outline-warning">@(seat.Status == LibrarySeatReservation.Web.Models.Entities.SeatStatus.Maintenance ? "恢复" : "维护")</button>
                                </form>
                            }
                            <form asp-controller="Admin" asp-action="DeleteSeat" method="post" style="display:inline;" onsubmit="return confirm('确定删除座位 @seat.SeatNumber？')">
                                <input type="hidden" name="id" value="@seat.Id" />
                                <button class="btn btn-sm btn-outline-danger">删除</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">暂无座位数据，请先新增座位</div>
}

<div class="modal fade" id="addModal"><div class="modal-dialog"><div class="modal-content">
    <form asp-controller="Admin" asp-action="AddSeat" method="post">
        <div class="modal-header"><h5 class="modal-title">新增座位</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-2"><label class="form-label small">编号</label><input name="SeatNumber" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label small">区域</label><input name="Area" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label small">楼层</label><input name="Floor" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label small">描述</label><input name="Description" class="form-control" /></div>
        </div>
        <div class="modal-footer"><button class="btn btn-primary">保存</button></div>
    </form>
</div></div></div>

@foreach (var seat in Model)
{
    <div class="modal fade" id="editModal_@seat.Id"><div class="modal-dialog"><div class="modal-content">
        <form asp-controller="Admin" asp-action="EditSeat" method="post">
            <input type="hidden" name="Id" value="@seat.Id" />
            <div class="modal-header"><h5 class="modal-title">编辑 @seat.SeatNumber</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-2"><label class="form-label small">编号</label><input name="SeatNumber" class="form-control" value="@seat.SeatNumber" /></div>
                <div class="mb-2"><label class="form-label small">区域</label><input name="Area" class="form-control" value="@seat.Area" /></div>
                <div class="mb-2"><label class="form-label small">楼层</label><input name="Floor" class="form-control" value="@seat.Floor" /></div>
                <div class="mb-2"><label class="form-label small">描述</label><input name="Description" class="form-control" value="@seat.Description" /></div>
            </div>
            <div class="modal-footer"><button class="btn btn-primary">保存</button></div>
        </form>
    </div></div></div>
}
