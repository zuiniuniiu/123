@model List<LibrarySeatReservation.Web.Models.Entities.Reservation>
@{ Layout = null; ViewData["Title"] = "预约管理"; }
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>预约管理</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Admin" asp-action="Reservation">管理后台</a>
            <div class="d-flex gap-2">
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Reservation">预约管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Seat">座位管理</a>
                <a class="nav-link text-white" asp-controller="Admin" asp-action="Statistics">统计</a>
                <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline">
                    <button class="btn btn-sm btn-outline-light">退出</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-fluid p-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        <h5 class="fw-semibold mb-3">预约管理</h5>
        <form method="get" class="mb-2">
            <select name="status" class="form-select w-auto d-inline" onchange="this.form.submit()">
                <option value="">全部</option>
                <option value="0">已预约</option>
                <option value="1">已完成</option>
                <option value="2">已取消</option>
            </select>
            <span class="small text-muted ms-2">共 @Model.Count 条</span>
        </form>
        @if (Model.Any())
        {
            <table class="table table-striped table-hover small">
                <thead><tr><th>ID</th><th>用户</th><th>座位</th><th>日期</th><th>时段</th><th>状态</th><th></th></tr></thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.Id</td><td>@r.UserName</td><td>@r.Seat?.SeatNumber</td>
                            <td>@r.ReservationDate.ToString("yyyy-MM-dd")</td><td>@r.TimeSlot</td>
                            <td>
                                @switch (r.Status)
                                {
                                    case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Active: <span class="badge bg-primary">已预约</span> break;
                                    case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Completed: <span class="badge bg-success">已完成</span> break;
                                    case LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Cancelled: <span class="badge bg-secondary">已取消</span> break;
                                }
                            </td>
                            <td>
                                @if (r.Status == LibrarySeatReservation.Web.Models.Entities.ReservationStatus.Active)
                                {
                                    <form asp-controller="Admin" asp-action="MarkCompleted" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button class="btn btn-sm btn-outline-success">标记完成</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else { <div class="alert alert-info">暂无预约记录</div> }
    </div>
</body>
</html>
